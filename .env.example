# ── Postgres ──────────────────────────────────────────────
POSTGRES_DB=qred_local
POSTGRES_USER=qred
POSTGRES_PASSWORD=qred_password

# ── Backend ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qred_local
DB_USER=qred
DB_PASSWORD=qred_password

# ── Auth ──────────────────────────────────────────────────
# Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-your-secret

# ── Frontend ──────────────────────────────────────────────
# Native dev: http://localhost:4000 | Docker: set automatically by compose
API_URL=http://localhost:4000
# Generate with: yarn workspace @qred/backend token:generate
API_TOKEN=
# Demo login credentials for the login page
DEMO_USERNAME=demo
DEMO_PASSWORD=password