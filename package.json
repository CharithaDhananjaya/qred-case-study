{
  "name": "qred-case-study",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure"
  ],
  "engines": {
    "node": "24.16.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "deploy:dev": "yarn workspace @qred/infrastructure deploy:dev",
    "deploy:prod": "yarn workspace @qred/infrastructure deploy:prod"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  }
}
