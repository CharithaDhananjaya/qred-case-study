{
  "name": "@qred/qred-scout",
  "version": "0.1.0",
  "private": true,
  "description": "Qred Scout — MCP server for API documentation search via Gemini embeddings and Pinecone",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "extract-docs": "ts-node scripts/extractDocs.ts",
    "ingest-docs": "ts-node scripts/ingestDocs.ts",
    "sync-docs": "yarn extract-docs && yarn ingest-docs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@pinecone-database/pinecone": "^3.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
